#include <iostream>
#include <string>
using namespace std;

int main() {
    string name;
    int rollNo;
    float marks;

    cout << "===== Student Record Application =====" << endl;

    cout << "Enter Student Name: ";
    getline(cin, name);

    cout << "Enter Roll Number: ";
    cin >> rollNo;

    cout << "Enter Marks: ";
    cin >> marks;

    cout << "\n----- Student Details -----" << endl;
    cout << "Name       : " << name << endl;
    cout << "Roll No.   : " << rollNo << endl;
    cout << "Marks      : " << marks << endl;

    if (marks >= 50)
        cout << "Result     : Pass" << endl;
    else
        cout << "Result     : Fail" << endl;

    return 0;
}
